rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: allocations
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required) - Unique ID
    //   - date: string (required) - ISO 8601 timestamp
    //   - totalUnits: number (required) - Total units allocated
    //   - allocations: map (required) - Name to count mapping
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidAllocation(data) {
      return data.date is string &&
             data.totalUnits is number &&
             data.allocations is map;
    }

    function isValidStaff(data) {
      return data.name is string &&
             data.region in ['TW', 'CN'] &&
             data.active is bool &&
             data.inOffice is bool;
    }

    match /allocations/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAllocation(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidStaff(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
